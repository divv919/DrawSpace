FROM node:22-alpine
RUN apk update
RUN apk add --no-cache libc6-compat

WORKDIR /app

COPY . .
RUN corepack enable
RUN npm i -g turbo
RUN turbo prune web --docker

RUN mkdir -p /app/pruned
RUN cp  -R /app/out/json/* /app/pruned
RUN cp  -R /app/out/full/* /app/pruned

RUN ls -R /app/out/full

WORKDIR /app/pruned


RUN CI=true pnpm install --frozen-lockfile
RUN cd /app/pruned/packages/db && pnpm exec prisma generate 

RUN pnpm turbo build --filter=web


CMD ["pnpm" , "start"]